# ============== Memos Worker 配置 ==============

# Memos Worker API 地址
MEMOS_API_URL=https://memos.aizhi.app

# RSS Ingest Token (从 memos-worker 环境变量中获取)
RSS_INGEST_TOKEN=your_token_here

# ============== RssHub 配置 ==============

# 数据库
DATABASE_URL=sqlite:///./data/rss.db
CHROMA_PERSIST_DIR=./chroma_db

# LLM API
LLM_BASE_URL=https://api.example.com/v1
LLM_API_KEY=sk-xxx
LLM_MODEL=your-model-name

# Embedding API
EMBEDDING_BASE_URL=https://api.example.com/v1
EMBEDDING_API_KEY=sk-xxx
EMBEDDING_MODEL=your-embedding-model

# 定时任务
SCHEDULER_ENABLED=true
SYNC_INTERVAL_HOURS=1
PREFERENCE_UPDATE_INTERVAL_HOURS=24

# RSS 抓取
MAX_ITEMS_PER_FEED=50
FETCH_TIMEOUT=30

# Jina.ai 全文抓取
JINA_RATE_LIMIT_SECONDS=2

# 分享链接
SHARE_BASE_URL=http://localhost:8000/share
